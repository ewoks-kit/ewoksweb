{
  "name": "ewoks-web",
  "homepage": ".",
  "private": true,
  "version": "0.0.1",
  "description": "Visualizer for Ewoks workflows",
  "author": "European Synchrotron Radiation Facility",
  "license": "MIT",
  "engines": {
    "node": "16.18.0",
    "pnpm": "8.x"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:pages": "vite build --base=/ewoks/ewoksweb/",
    "build:package": "VITE_SERVER_URL='/' pnpm build",
    "preview": "vite preview",
    "postbuild": "node postbuild.js",
    "lint": "run-p lint:**",
    "lint:eslint": "eslint \"**/*.{ts,tsx,js,jsx}\" --max-warnings=0",
    "lint:tsc": "tsc",
    "lint:tsc:cypress": "tsc --project cypress/tsconfig.json",
    "lint:prettier": "prettier --check .",
    "analyze": "npx source-map-explorer 'build/static/js/*.js'",
    "cypress": "cypress open --e2e --browser firefox",
    "cypress:run": "cypress run --e2e"
  },
  "dependencies": {
    "@emotion/react": "11.11.1",
    "@emotion/styled": "11.11.0",
    "@microlink/react-json-view": "1.22.2",
    "@mui/icons-material": "5.14.13",
    "@mui/lab": "5.0.0-alpha.148",
    "@mui/material": "5.14.13",
    "@mui/styles": "5.14.13",
    "@react-hookz/web": "23.1.0",
    "@tanstack/react-query": "4.35.7",
    "axios": "1.5.1",
    "d3-format": "3.1.0",
    "elkjs": "0.8.2",
    "lodash": "4.17.21",
    "nanoid": "4.0.2",
    "normalize.css": "^8.0.1",
    "path-browserify": "1.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-draggable": "4.4.6",
    "react-error-boundary": "4.0.11",
    "react-hook-form": "7.47.0",
    "react-reflex": "4.1.0",
    "react-router-dom": "6.16.0",
    "react-timeago": "7.2.0",
    "reactflow": "11.9.2",
    "socket.io-client": "4.7.2",
    "zustand": "4.4.3"
  },
  "devDependencies": {
    "@testing-library/cypress": "10.0.1",
    "@types/d3-format": "3.0.2",
    "@types/lodash": "^4.14.199",
    "@types/node": "^16.18.0",
    "@types/path-browserify": "1.0.0",
    "@types/react": "^18.2.27",
    "@types/react-dom": "^18.2.12",
    "@types/react-timeago": "^4.1.4",
    "@vitejs/plugin-react": "4.0.4",
    "cypress": "13.3.0",
    "cypress-wait-for-stable-dom": "0.1.0",
    "eslint": "8.50.0",
    "eslint-config-galex": "4.5.2",
    "npm-run-all": "4.1.5",
    "prettier": "3.0.3",
    "typescript": "4.9.3",
    "vite": "4.4.8",
    "web-worker": "1.2.0"
  },
  "browserslist": {
    "production": [
      ">1%",
      "Firefox 60",
      "Firefox ESR",
      "not ie 11",
      "not op_mini all",
      "not dead"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@phenomnomnominal/tsquery>typescript": "5.x",
        "eslint-plugin-etc>typescript": "5.x",
        "flux>react": "18.x",
        "@mui/styles>react": "18.x"
      }
    }
  }
}
